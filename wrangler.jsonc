{
  "name": "andreinc-hugo",
  "compatibility_date": "2026-03-10",
  "assets": {
    "directory": "./public",
    "html_handling": "auto-trailing-slash"
  },
  "routes": [
    { "pattern": "andreinc.net", "custom_domain": true },
    { "pattern": "www.andreinc.net", "custom_domain": true }
  ],
  "build": {
    "command": "hugo"
  }
}